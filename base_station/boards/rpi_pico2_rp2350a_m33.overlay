&spi0 {
    status = "disabled";
};

/ {
    aliases {
        led0 = &user_led0;
        buzzer = &buzzer_pin;
    };

    leds {
        compatible = "gpio-leds";

        user_led0: user_led0 {
            gpios = <&gpio0 25 GPIO_ACTIVE_HIGH>;
        };

        buzzer_pin: buzzer_pin {
            gpios = <&gpio0 22 GPIO_ACTIVE_HIGH>;
        };
    };
};